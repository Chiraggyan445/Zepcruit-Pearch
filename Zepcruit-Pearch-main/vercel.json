{
  "rewrites": [
    {
      "source": "/calculator",
      "destination": "https://zepcruit-calculator.vercel.app"
    },
    {
      "source": "/calculator/:path*",
      "destination": "https://zepcruit-calculator.vercel.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}